# ============================================================================
# OrthoPlus Enterprise - Environment Configuration for Ubuntu Server
# ============================================================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commit este arquivo no controle de versão!
#
# Deploy Ubuntu Server LTS:
#   1. cp .env.ubuntu.example .env
#   2. Edite as variáveis abaixo
#   3. sudo ./scripts/deploy-ubuntu.sh
# ============================================================================

# ============================================================================
# SEGURANÇA (CRÍTICO - NÃO IGNORE)
# ============================================================================

# JWT Secret - Gere com: openssl rand -base64 32
# Mínimo 32 caracteres. NUNCA use valor padrão em produção!
JWT_SECRET=SUBSTITUA_POR_CHAVE_SEGURA_DE_32_CARACTERES_MIN

# ============================================================================
# BANCO DE DADOS - POSTGRESQL (ÚNICO SUPORTADO EM PRODUÇÃO)
# ============================================================================
# O OrthoPlus v2.0+ suporta APENAS PostgreSQL em produção
# Não use SQLite, MariaDB ou Firebird em ambiente de produção

# Senha do banco de dados - Mínimo 12 caracteres, use caracteres mistos
DB_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_POSTGRESQL_123

# ============================================================================
# REDIS
# ============================================================================

# Senha do Redis - Mínimo 16 caracteres
REDIS_PASSWORD=SUBSTITUA_POR_SENHA_REDIS_FORTE

# ============================================================================
# CORS - Domínios permitidos (separados por vírgula)
# ============================================================================
# NUNCA use '*' em produção! Liste apenas domínios autorizados.
# Exemplo: https://app.orthoplus.com.br,https://www.orthoplus.com.br
ALLOWED_ORIGINS=https://orthoplus.i9corp.com.br

# ============================================================================
# FRONTEND
# ============================================================================
VITE_API_BASE_URL=/api

# ============================================================================
# EMAIL (Opcional - configure para enviar notificações)
# ============================================================================
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# MONITORAMENTO
# ============================================================================
GRAFANA_PASSWORD=SUBSTITUA_POR_SENHA_GRAFANA

# ============================================================================
# NOTAS DE SEGURANÇA
# ============================================================================
# ANTES do deploy em produção, verifique:
#
# ✅ JWT_SECRET é uma chave aleatória forte (256-bit)
# ✅ DB_PASSWORD tem pelo menos 12 caracteres complexos
# ✅ REDIS_PASSWORD tem pelo menos 16 caracteres
# ✅ ALLOWED_ORIGINS lista apenas domínios de produção
# ✅ Firewall UFW está ativo (portas 22, 80, 443)
# ✅ Fail2ban está instalado e configurado
# ✅ Backups automáticos estão configurados
#
# COMANDOS ÚTEIS:
#   docker compose logs -f backend    # Ver logs do backend
#   docker compose ps                 # Status dos containers
#   ./scripts/backup.sh               # Backup manual
#
# Para suporte: consulte docs/DEPLOYMENT_UBUNTU.md
# ============================================================================
