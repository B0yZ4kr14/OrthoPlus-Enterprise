# ============================================================================
# OrthoPlus — Production Environment Variables Example
# ============================================================================
# Copy this file to .env.production and fill in the real values.
# NEVER commit .env.production to version control.
#
# SECURITY NOTICE: Variables marked [OBRIGATÓRIO SEGURANÇA] são críticas para
# a segurança do sistema. Não altere os valores padrão seguros sem justificativa.
#
# Valide este arquivo antes do deploy com: ./scripts/validate-production.sh
# ============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
# Porta deve ser 3005 para consistência com nginx.conf e docker-compose.prod.yml
PORT=3005
LOG_LEVEL=info

# ─── Security ────────────────────────────────────────────────────────────────
# [OBRIGATÓRIO SEGURANÇA] Gere com: openssl rand -base64 32
# Mínimo 32 caracteres. Nunca use valores padrão ou previsíveis.
JWT_SECRET=<generate-with-openssl-rand-base64-32>

# [OBRIGATÓRIO SEGURANÇA] DEVE ser false em produção.
# true permite login sem banco de dados — NUNCA habilite em produção!
AUTH_ALLOW_MOCK=false

# [OBRIGATÓRIO SEGURANÇA] DEVE ser false em produção.
# true expõe endpoints de administração perigosos (truncate, delete all, etc).
# NUNCA habilite em produção!
ENABLE_DANGEROUS_ADMIN_ENDPOINTS=false

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=<your-postgres-host>
DB_PORT=5432
DB_NAME=orthoplus
DB_USER=orthoplus
DB_PASSWORD=<strong-database-password>

# [OBRIGATÓRIO SEGURANÇA] DEVE ser true em produção para criptografar conexão.
DB_SSL=true

# Full connection string (used by Prisma) — replace placeholders with actual values
# sslmode=require garante que a conexão é sempre criptografada
DATABASE_URL=postgresql://orthoplus:<strong-database-password>@<your-postgres-host>:5432/orthoplus?sslmode=require

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:<strong-redis-password>@redis:6379
# [OBRIGATÓRIO SEGURANÇA] Redis sem senha é um vetor de ataque sério. Defina sempre.
REDIS_PASSWORD=<strong-redis-password>

# ─── CORS ────────────────────────────────────────────────────────────────────
# [OBRIGATÓRIO SEGURANÇA] Liste apenas os domínios autorizados. NUNCA use '*'.
# Comma-separated list of allowed origins. Example: https://app.orthoplus.com.br
ALLOWED_ORIGINS=https://orthoplus.i9corp.com.br

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://orthoplus.i9corp.com.br/api

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@your-domain.com.br
SMTP_PASS=<smtp-password>
SMTP_FROM=OrthoPlus <noreply@your-domain.com.br>

# ─── Video Conferencing (Agora) ──────────────────────────────────────────────
AGORA_APP_ID=<your-agora-app-id>
AGORA_APP_CERTIFICATE=<your-agora-app-certificate>

# ─── Nginx ────────────────────────────────────────────────────────────────────
# [OBRIGATÓRIO SEGURANÇA] Substitua pelo domínio real de produção.
# Este valor deve corresponder ao domínio configurado no certificado SSL.
# ATENÇÃO: Após definir este valor, substitua manualmente 'server_name _' por
# 'server_name <NGINX_SERVER_NAME>' no arquivo nginx.conf antes do deploy.
NGINX_SERVER_NAME=orthoplus.i9corp.com.br

# ─── Observability ───────────────────────────────────────────────────────────
GRAFANA_PASSWORD=<strong-grafana-password>
