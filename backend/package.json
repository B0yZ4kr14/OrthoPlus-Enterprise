{
  "name": "orthoplus-backend",
  "version": "1.0.0",
  "description": "Ortho+ Backend - Modular Monolith with API Gateway",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "ESLINT_USE_FLAT_CONFIG=false ./node_modules/.bin/eslint src --ext .ts",
    "predeploy": "node -e \"const r=(k)=>{if(!process.env[k])throw new Error('Missing env: '+k)};['JWT_SECRET','DATABASE_URL'].forEach(r);if(process.env.AUTH_ALLOW_MOCK==='true')throw new Error('AUTH_ALLOW_MOCK=true is not allowed in production');console.log('predeploy checks passed');\""
  },
  "dependencies": {
    "@orthoplus/shared-types": "workspace:*",
    "@prisma/client": "^6.4.1",
    "tsconfig-paths": "^4.2.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
